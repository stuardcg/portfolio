---
import { PORTFOLIO_DATA } from "../data/portfolio";

const { name, version } = PORTFOLIO_DATA;
const mark = `PORTFOLIO · ${version} · ${name.split(" ")[0].toUpperCase()}`;
---

<div class="side-rail">
    <div class="glyph">
        <div>◢</div>
        <div>◤</div>
        <div>◢</div>
    </div>
    <div class="spacer"></div>
    <div class="mark">{mark}</div>
    <div class="spacer"></div>
    <div class="glyph">
        <div>▚</div>
        <div>▞</div>
        <div>▚</div>
    </div>
</div>

<style>
    .side-rail {
        position: fixed;
        inset: 28px auto 28px 0;
        width: 56px;
        z-index: 40;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 18px 0;
        background: var(--base);
        border-right: 1px solid var(--rule);
    }

    .glyph {
        font-family: var(--font-mono);
        font-size: 10px;
        text-align: center;
        line-height: 1;
        color: var(--muted);
    }

    .spacer {
        flex: 1;
        width: 1px;
        margin: 14px 0;
        background: var(--rule);
    }

    .mark {
        font-family: var(--font-mono);
        font-size: 10px;
        letter-spacing: 0.4em;
        color: var(--faint);
        writing-mode: vertical-rl;
        transform: rotate(180deg);
    }

    @media (max-width: 720px) {
        .side-rail {
            display: none;
        }
    }
</style>
