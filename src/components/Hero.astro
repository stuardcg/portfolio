---
import { ASCII_HUSKY, PORTFOLIO_DATA } from "../data/portfolio";
import TypedRole from "./TypedRole";

const { name, initials, role, availability, statusLabel, focus, craft, location, contact } =
	PORTFOLIO_DATA;

const [firstName, ...rest] = name.split(" ");
const lastName = rest.join(" ");

const label = `${initials} // ${role.toUpperCase()} · ${availability}`;

const meta = [
	{ k: "// FOCUS", v: focus },
	{ k: "// CRAFT", v: craft },
	{ k: "// STATUS", v: `● ${statusLabel}`, ok: true },
	{ k: "// BASE", v: `Remote · ${location.timezone}` },
];

const husky = ASCII_HUSKY.replace(/^\n/, "");

const stripProto = (url: string) => url.replace(/^https?:\/\//, "");

const channels = [
	{ label: stripProto(contact.github), href: contact.github, external: true },
	{ label: stripProto(contact.linkedin), href: contact.linkedin, external: true },
	{ label: contact.email, href: `mailto:${contact.email}`, external: false },
];
---

<section id="hero" class="hero">
	<div>
		<div class="label">{label}</div>
		<h1 class="name">
			<span class="glitch" data-text={firstName}>{firstName}</span>
			<br />
			<span class="accent glitch" data-text={`${lastName}.`}
				>{lastName}<span class="period">.</span></span
			>
		</h1>
		<TypedRole client:load roles={PORTFOLIO_DATA.roles} />
		<dl class="meta">
			{
				meta.map((item) => (
					<div class="meta-item">
						<dt class="k">{item.k}</dt>
						<dd class={`v ${item.ok ? "ok" : ""}`}>{item.v}</dd>
					</div>
				))
			}
		</dl>
	</div>

	<div class="aside">
		<pre class="portrait">{husky}</pre>
		<nav id="contact" class="channels" aria-label="Contact channels">
			{
				channels.map((c) => (
					<a
						class="channel"
						href={c.href}
						target={c.external ? "_blank" : undefined}
						rel={c.external ? "noopener noreferrer" : undefined}
					>
						{c.label}
					</a>
				))
			}
			<a class="channel cv" href={contact.cv} download>download CV</a>
		</nav>
	</div>
</section>

<style>
	.hero {
		min-height: calc(100vh - 56px);
		display: grid;
		grid-template-columns: 1.3fr 1fr;
		gap: 64px;
		/* center the whole block in the viewport; stretch the columns to equal
		   height so the name/terminal share a top edge and the meta/channels
		   (pinned to the bottom of each column) share a bottom edge */
		align-content: center;
		align-items: stretch;
		padding: 80px 0 60px;
	}

	.aside {
		display: flex;
		flex-direction: column;
		/* lets the portrait font scale to the column width (see .portrait) */
		container-type: inline-size;
	}

	:global([data-density="compact"]) .hero {
		padding: 56px 0 40px;
		min-height: auto;
	}

	@media (max-width: 900px) {
		.hero {
			grid-template-columns: 1fr;
			gap: 32px;
			padding: 48px 0;
		}
	}

	.label {
		font-family: var(--font-mono);
		font-size: 11px;
		color: var(--accent);
		letter-spacing: 0.2em;
		margin-bottom: 24px;
		display: flex;
		align-items: center;
		gap: 12px;
	}

	.label::before {
		content: "";
		width: 28px;
		height: 1px;
		background: var(--accent);
	}

	.name {
		font-size: clamp(56px, 8vw, 112px);
		font-weight: 600;
		line-height: 0.92;
		letter-spacing: -0.04em;
		margin: 0 0 28px;
		color: var(--strong);
	}

	.name .accent {
		color: var(--accent);
	}

	.period {
		color: var(--faint);
	}

	.meta {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 20px;
		max-width: 480px;
		margin: 28px 0 0;
		padding-top: 28px;
		border-top: 1px solid var(--rule);
	}

	.k {
		font-family: var(--font-mono);
		font-size: 10px;
		color: var(--faint);
		letter-spacing: 0.15em;
		margin-bottom: 6px;
	}

	.v {
		margin: 0;
		font-size: 14px;
		color: var(--strong);
	}

	.v.ok {
		color: var(--ok);
	}

	.portrait {
		margin: 0;
		font-family: var(--font-mono);
		/* the art is a fixed 60 columns; scale the font to the column width so
		   it never overflows on narrow screens, capped at 10px on desktop */
		font-size: clamp(5px, 2.15cqw, 10px);
		line-height: 1.05;
		color: var(--accent);
		white-space: pre;
		background: var(--surface);
		padding: 24px;
		border: 1px solid var(--rule);
		position: relative;
	}

	.portrait::before {
		content: "◢ PORTRAIT";
		position: absolute;
		top: -10px;
		left: 16px;
		background: var(--base);
		padding: 0 8px;
		font-size: 9px;
		letter-spacing: 0.2em;
		color: var(--faint);
	}

	.channels {
		/* auto top margin pins the block to the bottom of the stretched
		   column so it lines up with the meta block on the left */
		margin-top: auto;
		padding-top: 18px;
		display: flex;
		flex-direction: column;
		gap: 2px;
		font-family: var(--font-mono);
		font-size: 13px;
	}

	.channel {
		width: fit-content;
		padding: 6px 0;
		color: var(--strong);
		text-decoration: none;
		position: relative;
	}

	.channel::after {
		content: "↗";
		margin-left: 8px;
		display: inline-block;
		color: var(--faint);
		transition: transform 160ms;
	}

	.channel:hover {
		color: var(--accent);
	}

	.channel:hover::after {
		transform: translate(2px, -2px);
		color: var(--accent);
	}

	.channel.cv {
		margin-top: 14px;
		color: var(--accent);
		letter-spacing: 0.05em;
	}

	.channel.cv::after {
		content: "↓";
	}

	.channel.cv:hover::after {
		transform: translateY(2px);
	}
</style>
